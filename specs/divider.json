{
  "component": "Divider",
  "description": "시각적 구분선 컴포넌트. 수평/수직 방향, 내장 스페이싱 프리셋, 라벨 삽입 지원. 기존 SideNavDivider, DropdownMenuSeparator 패턴을 범용화한 독립 컴포넌트.",
  "classification": "Primitive (non-interactive, display-only)",

  "props": {
    "orientation": {
      "type": "'horizontal' | 'vertical'",
      "default": "horizontal",
      "description": "구분선 방향. horizontal = 가로선(width:100%), vertical = 세로선(height:100%).",
      "metadataArray": "DIVIDER_ORIENTATIONS"
    },
    "spacing": {
      "type": "'none' | 'compact' | 'default' | 'spacious'",
      "default": "default",
      "description": "구분선 양쪽 여백 프리셋. horizontal → margin-y, vertical → margin-x.",
      "metadataArray": "DIVIDER_SPACINGS"
    },
    "weight": {
      "type": "'thin' | 'thick'",
      "default": "thin",
      "description": "선 두께. thin = 1px, thick = 2px.",
      "metadataArray": "DIVIDER_WEIGHTS"
    },
    "variant": {
      "type": "'solid' | 'dashed' | 'dotted'",
      "default": "solid",
      "description": "선 스타일.",
      "metadataArray": "DIVIDER_VARIANTS"
    },
    "label": {
      "type": "string",
      "default": null,
      "description": "선 위에 표시할 텍스트. horizontal에서만 동작. 라벨이 있으면 선이 좌우로 분할됨."
    },
    "labelPosition": {
      "type": "'left' | 'center' | 'right'",
      "default": "center",
      "description": "라벨 위치. label prop이 있을 때만 유효.",
      "metadataArray": "DIVIDER_LABEL_POSITIONS"
    },
    "className": {
      "type": "string",
      "default": null,
      "description": "추가 CSS 클래스."
    }
  },

  "variants": {
    "orientation": {
      "horizontal": {
        "layout": "width: 100%, height: {weight}",
        "margin": "margin-y per spacing preset"
      },
      "vertical": {
        "layout": "height: 100%, width: {weight}, align-self: stretch",
        "margin": "margin-x per spacing preset"
      }
    },
    "spacing": {
      "none": {
        "margin": "0px"
      },
      "compact": {
        "margin": "4px (spacing-1)"
      },
      "default": {
        "margin": "8px (spacing-2)"
      },
      "spacious": {
        "margin": "16px (spacing-4)"
      }
    },
    "weight": {
      "thin": {
        "thickness": "1px"
      },
      "thick": {
        "thickness": "2px"
      }
    },
    "variant": {
      "solid": {
        "style": "bg-[var(--comp-divider-color)] (no border, background-based)"
      },
      "dashed": {
        "style": "border-dashed border-[var(--comp-divider-color)]"
      },
      "dotted": {
        "style": "border-dotted border-[var(--comp-divider-color)]"
      }
    },
    "label": {
      "withLabel": {
        "layout": "display: flex, align-items: center, gap: 8px (spacing-2)",
        "lines": "flex: 1, height: {weight}px, bg or border per variant",
        "labelTypography": "typography-13-regular",
        "labelColor": "text-[var(--comp-divider-label-color)]"
      }
    }
  },

  "states": {
    "note": "Divider는 non-interactive 컴포넌트. hover, focus, pressed, disabled, loading 상태 없음."
  },

  "tokens": {
    "sizeSpacing": {
      "layer": ":root",
      "naming": "--comp-divider-{property}[-{variant}]",
      "list": [
        "--comp-divider-weight-thin: 1px",
        "--comp-divider-weight-thick: 2px",
        "--comp-divider-spacing-none: 0px",
        "--comp-divider-spacing-compact: var(--spacing-1)",
        "--comp-divider-spacing-default: var(--spacing-2)",
        "--comp-divider-spacing-spacious: var(--spacing-4)",
        "--comp-divider-label-gap: var(--spacing-2)"
      ]
    },
    "color": {
      "layer": "[data-theme]",
      "naming": "--comp-divider-{property}",
      "list": [
        "--comp-divider-color: var(--semantic-divider-solid-100)",
        "--comp-divider-label-color: var(--semantic-text-on-bright-500)"
      ]
    }
  },

  "implementation": {
    "pattern": "CVA + cn",
    "element": "div (role=separator for accessibility)",
    "labelElement": "When label is provided: flex container with two line spans + label text span",
    "solidRendering": "solid variant uses background-color (not border) — matches DropdownMenuSeparator pattern",
    "dashedDottedRendering": "dashed/dotted variants use border-style — requires border-width instead of height for horizontal, width for vertical",
    "verticalUsage": "Parent must have display:flex for vertical orientation to work (align-self: stretch needs flex parent)",
    "files": [
      "src/components/Divider/Divider.tsx",
      "src/components/Divider/index.ts"
    ],
    "dependencies": [],
    "exports": {
      "components": ["Divider"],
      "types": ["DividerProps", "DividerOrientation", "DividerSpacing", "DividerWeight", "DividerVariant", "DividerLabelPosition"],
      "metadata": ["DIVIDER_ORIENTATIONS", "DIVIDER_SPACINGS", "DIVIDER_WEIGHTS", "DIVIDER_VARIANTS", "DIVIDER_LABEL_POSITIONS"]
    }
  }
}
