{
  "component": "Tab",
  "description": "수평 탭 네비게이션 컴포넌트. underline(하단 슬라이딩 인디케이터)과 pill(배경 채우기) 두 가지 시각적 variant를 지원한다. 스크롤 가능한 탭 목록, 키보드 내비게이션, manual/automatic 활성화 모드를 제공한다.",
  "classification": "Compound",

  "subComponents": [
    {
      "name": "TabGroup",
      "role": "Root compound component. Context provider로 value, variant, size, disabled, activationMode를 자식에게 전파한다.",
      "element": "div",
      "props": {
        "value": {
          "type": "string",
          "description": "현재 선택된 탭의 value. 제공 시 controlled mode."
        },
        "defaultValue": {
          "type": "string",
          "description": "비제어 모드의 초기 선택값."
        },
        "onValueChange": {
          "type": "(value: string) => void",
          "description": "탭 변경 콜백."
        },
        "variant": {
          "type": "'underline' | 'pill'",
          "default": "underline",
          "description": "시각적 style variant. underline은 하단 슬라이딩 인디케이터, pill은 TabItem 배경 채우기."
        },
        "size": {
          "type": "'large' | 'medium'",
          "default": "large",
          "description": "크기. 높이, 패딩, 타이포그래피, 아이콘 크기, gap을 제어."
        },
        "disabled": {
          "type": "boolean",
          "default": false,
          "description": "모든 탭을 비활성화."
        },
        "activationMode": {
          "type": "'manual' | 'automatic'",
          "default": "manual",
          "description": "manual=포커스 이동과 선택 분리(Enter/Space로 명시적 선택), automatic=포커스 이동 시 자동 선택."
        },
        "children": { "type": "ReactNode" },
        "className": { "type": "string" }
      }
    },
    {
      "name": "TabList",
      "role": "스크롤 가능한 탭 버튼 컨테이너. 슬라이딩 인디케이터(underline)와 스크롤 페이드 그라디언트를 관리한다.",
      "element": "div[role=tablist]",
      "props": {
        "children": { "type": "ReactNode" },
        "className": { "type": "string" },
        "aria-label": {
          "type": "string",
          "description": "접근성 레이블."
        }
      }
    },
    {
      "name": "TabItem",
      "role": "개별 탭 버튼. Context에서 variant/size를 읽어 스타일링하고, value로 선택 상태를 결정한다.",
      "element": "button[role=tab]",
      "props": {
        "value": {
          "type": "string",
          "description": "탭의 고유 식별자. 연결된 TabPanel의 value와 일치해야 한다."
        },
        "disabled": {
          "type": "boolean",
          "default": false,
          "description": "이 탭만 개별 비활성화. aria-disabled 방식으로 포커스는 유지."
        },
        "icon": {
          "type": "ReactNode",
          "description": "탭 아이콘. 크기는 size variant에 의해 제어."
        },
        "badge": {
          "type": "ReactNode",
          "description": "뱃지 콘텐츠. Label 우측 상단에 absolute 배치."
        },
        "children": { "type": "ReactNode" },
        "className": { "type": "string" }
      }
    },
    {
      "name": "TabPanel",
      "role": "TabItem에 연결되는 콘텐츠 영역. value가 일치할 때만 렌더링.",
      "element": "div[role=tabpanel]",
      "props": {
        "value": {
          "type": "string",
          "description": "연결된 TabItem의 value와 일치해야 한다."
        },
        "forceMount": {
          "type": "boolean",
          "default": false,
          "description": "비활성 패널을 DOM에 유지할지 여부. true이면 hidden 상태로 렌더링."
        },
        "children": { "type": "ReactNode" },
        "className": { "type": "string" }
      }
    }
  ],

  "context": {
    "name": "TabContext",
    "sharedState": {
      "value": "현재 선택된 탭의 value",
      "onChange": "탭 변경 핸들러",
      "variant": "underline | pill",
      "size": "lg | sm",
      "disabled": "전체 비활성화 여부",
      "activationMode": "manual | automatic"
    }
  },

  "variants": {
    "variant": {
      "underline": {
        "description": "하단 슬라이딩 인디케이터. 탭 전환 시 인디케이터가 offsetLeft 기반으로 애니메이션 이동.",
        "tabItem": "rounded-none",
        "typography": { "large": "typography-17-semibold", "medium": "typography-13-semibold" },
        "indicator": "absolute bottom-0, transition-[left,width] duration-normal ease-move",
        "listBorder": "border-b border-[var(--comp-tab-border-underline)]"
      },
      "pill": {
        "description": "배경 채우기 방식. 선택 시 배경+텍스트 색 변경.",
        "tabItem": "rounded-[var(--comp-tab-radius-pill-{size})]",
        "typography": { "large": "typography-17-medium", "medium": "typography-13-medium" },
        "listBg": "bg-[var(--comp-tab-list-bg-pill)]",
        "listPaddingY": "py-[var(--comp-tab-list-padding-y-pill)]"
      }
    },
    "size": {
      "large": {
        "underline": {
          "height": "40px",
          "paddingX": "0px",
          "gap": "6px",
          "iconSize": "18px",
          "indicatorHeight": "2px"
        },
        "pill": {
          "height": "40px",
          "paddingX": "16px",
          "gap": "6px",
          "iconSize": "18px",
          "radius": "20px"
        }
      },
      "medium": {
        "underline": {
          "height": "32px",
          "paddingX": "0px",
          "gap": "4px",
          "iconSize": "14px",
          "indicatorHeight": "2px"
        },
        "pill": {
          "height": "32px",
          "paddingX": "12px",
          "gap": "4px",
          "iconSize": "14px",
          "radius": "16px"
        }
      }
    }
  },

  "states": {
    "default": {
      "underline": {
        "label": "var(--comp-tab-label-underline) → neutral-solid-500"
      },
      "pill": {
        "label": "var(--comp-tab-label-pill) → neutral-solid-500",
        "bg": "var(--comp-tab-bg-pill) → neutral-solid-70"
      }
    },
    "selected": {
      "underline": {
        "label": "var(--comp-tab-label-underline-selected) → neutral-solid-950",
        "indicator": "var(--comp-tab-indicator-underline) → neutral-solid-950"
      },
      "pill": {
        "label": "var(--comp-tab-label-pill-selected) → neutral-solid-0",
        "bg": "var(--comp-tab-bg-pill-selected) → neutral-solid-950"
      }
    },
    "hover": {
      "underline": "var(--comp-tab-hover-underline) → state-on-bright-50",
      "pill-default": "var(--comp-tab-hover-pill) → state-on-bright-50",
      "pill-selected": "var(--comp-tab-hover-pill-selected) → state-on-dim-50"
    },
    "pressed": {
      "underline": "var(--comp-tab-pressed-underline) → state-on-bright-70",
      "pill-default": "var(--comp-tab-pressed-pill) → state-on-bright-70",
      "pill-selected": "var(--comp-tab-pressed-pill-selected) → state-on-dim-70"
    },
    "disabled": {
      "underline": {
        "label": "var(--comp-tab-label-underline-disabled) → neutral-solid-400",
        "indicator": "var(--comp-tab-indicator-underline-disabled) → neutral-solid-200"
      },
      "pill": {
        "label": "var(--comp-tab-label-pill-disabled) → neutral-solid-400",
        "bg": "var(--comp-tab-bg-pill-disabled) → neutral-solid-70"
      }
    },
    "selected-disabled": {
      "underline": {
        "label": "var(--comp-tab-label-underline-selected-disabled) → neutral-solid-400"
      },
      "pill": {
        "label": "var(--comp-tab-label-pill-selected-disabled) → neutral-solid-400",
        "bg": "var(--comp-tab-bg-pill-selected-disabled) → neutral-solid-200"
      }
    },
    "focus": {
      "all": "focus-visible:ring-2 ring-[var(--comp-tab-focus-ring)] ring-offset-2 → primary-300"
    }
  },

  "tokens": {
    "sizeTokens": {
      "scope": ":root",
      "pattern": "--comp-tab-{property}-{variant}-{size}",
      "list": [
        "--comp-tab-height-underline-large: 40px",
        "--comp-tab-height-underline-medium: 32px",
        "--comp-tab-padding-x-underline-large: 0px",
        "--comp-tab-padding-x-underline-medium: 0px",
        "--comp-tab-gap-underline-large: 6px",
        "--comp-tab-gap-underline-medium: 4px",
        "--comp-tab-icon-size-underline-large: 18px",
        "--comp-tab-icon-size-underline-medium: 14px",
        "--comp-tab-indicator-height-underline-large: 2px",
        "--comp-tab-indicator-height-underline-medium: 2px",
        "--comp-tab-height-pill-large: 40px",
        "--comp-tab-height-pill-medium: 32px",
        "--comp-tab-padding-x-pill-large: 16px",
        "--comp-tab-padding-x-pill-medium: 12px",
        "--comp-tab-gap-pill-large: 6px",
        "--comp-tab-gap-pill-medium: 4px",
        "--comp-tab-icon-size-pill-large: 18px",
        "--comp-tab-icon-size-pill-medium: 14px",
        "--comp-tab-radius-pill-large: 20px",
        "--comp-tab-radius-pill-medium: 16px",
        "--comp-tab-list-gap-underline: 16px",
        "--comp-tab-list-gap-pill: 8px",
        "--comp-tab-list-padding-y-pill: 8px",
        "--comp-tab-scroll-fade-width: 24px"
      ]
    },
    "colorTokens": {
      "scope": "[data-theme]",
      "pattern": "--comp-tab-{property}-{variant}[-{state}]",
      "list": [
        "--comp-tab-label-underline: neutral-solid-500",
        "--comp-tab-label-underline-selected: neutral-solid-950",
        "--comp-tab-label-underline-disabled: neutral-solid-400",
        "--comp-tab-label-underline-selected-disabled: neutral-solid-400",
        "--comp-tab-indicator-underline: neutral-solid-950",
        "--comp-tab-indicator-underline-disabled: neutral-solid-200",
        "--comp-tab-border-underline: neutral-solid-200",
        "--comp-tab-hover-underline: state-on-bright-50",
        "--comp-tab-pressed-underline: state-on-bright-70",
        "--comp-tab-label-pill: neutral-solid-500",
        "--comp-tab-label-pill-selected: neutral-solid-0",
        "--comp-tab-label-pill-disabled: neutral-solid-400",
        "--comp-tab-label-pill-selected-disabled: neutral-solid-400",
        "--comp-tab-bg-pill: neutral-solid-70",
        "--comp-tab-bg-pill-selected: neutral-solid-950",
        "--comp-tab-bg-pill-disabled: neutral-solid-70",
        "--comp-tab-bg-pill-selected-disabled: neutral-solid-200",
        "--comp-tab-hover-pill: state-on-bright-50",
        "--comp-tab-pressed-pill: state-on-bright-70",
        "--comp-tab-hover-pill-selected: state-on-dim-50",
        "--comp-tab-pressed-pill-selected: state-on-dim-70",
        "--comp-tab-list-bg-pill: background-0",
        "--comp-tab-focus-ring: primary-300"
      ]
    }
  },

  "features": {
    "slidingIndicator": {
      "variant": "underline",
      "mechanism": "useLayoutEffect + offsetLeft/offsetWidth. 선택된 탭 버튼의 위치/너비를 읽어 absolute 인디케이터의 left/width를 갱신한다.",
      "transition": "transition-[left,width] duration-normal ease-move"
    },
    "scrollFadeGradient": {
      "mechanism": "ResizeObserver + scroll event. scrollLeft 값에 따라 좌/우 fade gradient를 표시/숨김.",
      "fadeWidth": "var(--comp-tab-scroll-fade-width) = 24px",
      "gradient": "linear-gradient(to right/left, var(--semantic-background-0), transparent)"
    },
    "keyboardNavigation": {
      "role": "tablist",
      "keys": {
        "ArrowRight": "다음 탭으로 포커스 이동",
        "ArrowLeft": "이전 탭으로 포커스 이동",
        "Home": "첫 번째 탭으로 이동",
        "End": "마지막 탭으로 이동",
        "Enter/Space": "manual 모드에서 탭 선택"
      },
      "automatic": "포커스 이동 시 자동 선택",
      "wrapAround": true,
      "disabledSkip": "aria-disabled 탭은 포커스 대상에서 제외"
    },
    "scrollIntoView": "value 변경 시 선택된 탭을 scrollIntoView({ behavior: 'smooth' })로 뷰포트에 노출"
  },

  "accessibility": {
    "roles": {
      "tablist": "TabList container",
      "tab": "각 TabItem",
      "tabpanel": "각 TabPanel"
    },
    "attributes": {
      "aria-selected": "선택된 탭에 true",
      "aria-controls": "tab → tabpanel 연결 (tabpanel-{value})",
      "aria-labelledby": "tabpanel → tab 연결 (tab-{value})",
      "aria-disabled": "비활성 탭에 설정 (포커스 유지)",
      "aria-orientation": "horizontal"
    },
    "tabIndex": "선택된 탭만 0, 나머지 -1 (roving tabindex)"
  },

  "implementation": {
    "pattern": "Compound Component + Context + CVA + cn",
    "stateOverlay": "sibling <span> + group-hover/group-active, rounded-[inherit]",
    "files": [
      "src/components/Tab/Tab.tsx",
      "src/components/Tab/index.ts"
    ],
    "dependencies": [],
    "variantMetadata": {
      "TAB_VARIANTS": ["underline", "pill"],
      "TAB_SIZES": ["large", "medium"]
    },
    "exportedTypes": ["TabGroupProps", "TabListProps", "TabItemProps", "TabPanelProps", "TabVariant", "TabSize"]
  }
}
