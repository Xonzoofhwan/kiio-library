    "shape": {
      "type": "'rectangle' | 'circular'",
      "default": "rectangle",
      "description": "Rectangle uses standard radius, Circular uses pill radius."
    },
    "placeholder": {
      "type": "string",
      "default": "Search..."
    },
    "iconLeading": {
      "type": "ReactNode",
      "default": "SearchIcon (built-in)",
      "description": "Leading icon. Defaults to search icon."
    },
    "clearButton": {
      "type": "boolean",
      "default": true,
      "description": "Shows clear (X) button when input has value."
    },
    "searchButton": {
      "type": "boolean",
      "default": false,
      "description": "Shows search button on the trailing side."
    },
    "disabled": {
      "type": "boolean",
      "default": false
