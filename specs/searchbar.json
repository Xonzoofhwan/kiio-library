{
  "component": "SearchBar",
  "description": "Search input with leading icon, optional clear/search buttons, and two shape variants (rectangle/circular). 4 sizes matching the Input component height system.",
  "figmaNode": "7329:25303",

  "props": {
    "size": {
      "type": "'xLarge' | 'large' | 'medium' | 'small'",
      "default": "medium"
