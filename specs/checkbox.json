{
  "component": "Checkbox",
  "description": "Accessible checkbox with checked, unchecked, and indeterminate states. Built on @radix-ui/react-checkbox for keyboard and screen reader support. Supports optional label.",

  "props": {
    "size": {
      "type": "'large' | 'medium' | 'small'",
      "default": "medium"
    },
    "checked": {
      "type": "boolean | 'indeterminate'",
      "default": false,
      "description": "Controlled checked state. 'indeterminate' shows dash icon."
    },
    "onCheckedChange": {
      "type": "(checked: boolean | 'indeterminate') => void",
      "default": null,
      "description": "Callback when checked state changes."
    },
    "label": {
      "type": "string",
      "default": null,
      "description": "Label text displayed next to the checkbox."
    },
    "disabled": {
      "type": "boolean",
      "default": false,
      "description": "Inactive state. Prevents interaction."
    },
    "required": {
      "type": "boolean",
      "default": false
    },
    "name": {
      "type": "string",
      "default": null,
      "description": "Name attribute for form submission."
    },
    "value": {
      "type": "string",
      "default": "on",
      "description": "Value attribute for form submission."
    }
  },

  "variants": {
    "size": {
      "large": {
        "boxSize": "size-5 (20px)",
        "radius": "rounded-1 (4px)",
        "iconSize": "size-3.5 (14px)",
        "labelTypography": "typography-16-regular",
        "gap": "gap-2 (8px)"
      },
      "medium": {
        "boxSize": "size-4.5 (18px)",
        "radius": "rounded-1 (4px)",
        "iconSize": "size-3 (12px)",
        "labelTypography": "typography-14-regular",
        "gap": "gap-2 (8px)"
      },
      "small": {
        "boxSize": "size-4 (16px)",
        "radius": "rounded-0.5 (2px)",
        "iconSize": "size-2.5 (10px)",
        "labelTypography": "typography-13-regular",
        "gap": "gap-1.5 (6px)"
      }
    }
  },

  "states": {
    "unchecked": {
      "background": "transparent",
      "border": "border-2 border-sys-neutral-black-alpha-300",
      "icon": "none"
    },
    "checked": {
      "background": "bg-sys-neutral-solid-950",
      "border": "none",
      "icon": "check icon, text-sys-neutral-solid-0"
    },
    "indeterminate": {
      "background": "bg-sys-neutral-solid-950",
      "border": "none",
      "icon": "dash icon, text-sys-neutral-solid-0"
    },
    "hover": {
      "unchecked": "border-sys-neutral-black-alpha-600",
      "checked": "state overlay: sys-state-on-dim-50"
    },
    "focused": {
      "all": "ring-2 ring-sys-primary-300 ring-offset-2 (focus-visible only)"
    },
    "disabled": {
      "unchecked": {
        "background": "transparent",
        "border": "border-2 border-sys-neutral-black-alpha-200"
      },
      "checked": {
        "background": "bg-sys-neutral-solid-300",
        "icon": "text-sys-neutral-white-alpha-400"
      },
      "label": "text-sys-neutral-black-alpha-200"
    }
  },

  "implementation": {
    "pattern": "CVA + cn + @radix-ui/react-checkbox",
    "structure": "Wrapper (flex, gap) → Radix Checkbox.Root (styled box) → Checkbox.Indicator (check/dash icon) + Label (<label> element)",
    "iconStrategy": "Inline SVG for check mark and dash. Animated with scale transition.",
    "files": [
      "src/components/Checkbox/Checkbox.tsx",
      "src/components/Checkbox/index.ts"
    ],
    "dependencies": [
      "@radix-ui/react-checkbox"
    ]
  }
}
