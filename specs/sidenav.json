{
  "component": "SideNav",
  "description": "수직 네비게이션/탭 컴포넌트. 접기/펼치기 가능한 그룹, 아이콘, 뱃지, 구분선을 지원한다. Context를 통해 value, size, disabled를 자식에 전파하며, SideNavPanel로 vertical tab 패턴도 구현 가능하다.",
  "classification": "Compound",

  "subComponents": [
    {
      "name": "SideNav",
      "role": "Root compound component. <nav> element. Context provider로 value, size, disabled를 자식에게 전파.",
      "element": "nav",
      "props": {
        "value": {
          "type": "string",
          "description": "현재 선택된 아이템의 value. 제공 시 controlled mode."
        },
        "defaultValue": {
          "type": "string",
          "description": "비제어 모드의 초기 선택값."
        },
        "onValueChange": {
          "type": "(value: string) => void",
          "description": "선택 변경 콜백."
        },
        "size": {
          "type": "'large' | 'medium' | 'small'",
          "default": "medium",
          "description": "아이템 크기. 높이, 패딩, 타이포그래피, 아이콘 크기를 제어."
        },
        "disabled": {
          "type": "boolean",
          "default": false,
          "description": "모든 아이템 비활성화."
        },
        "children": { "type": "ReactNode" },
        "className": { "type": "string" }
      }
    },
    {
      "name": "SideNavGroup",
      "role": "접기/펼치기가 가능한 그룹 섹션. 헤더 버튼 + collapsible content 구조.",
      "element": "div > button (header) + div (collapsible content)",
      "props": {
        "label": {
          "type": "string",
          "description": "그룹 헤더에 표시할 레이블."
        },
        "defaultExpanded": {
          "type": "boolean",
          "default": true,
          "description": "초기 펼침 상태."
        },
        "collapsible": {
          "type": "boolean",
          "default": true,
          "description": "접기 가능 여부. false이면 항상 펼쳐져 있고 chevron 아이콘이 숨겨진다."
        },
        "children": { "type": "ReactNode" },
        "className": { "type": "string" }
      }
    },
    {
      "name": "SideNavItem",
      "role": "개별 네비게이션 아이템. Context에서 size를 읽어 스타일링하고, value로 active 상태를 결정.",
      "element": "li > button",
      "props": {
        "value": {
          "type": "string",
          "description": "고유 식별자. SideNav의 value와 매칭."
        },
        "icon": {
          "type": "ReactNode",
          "description": "좌측 아이콘. 크기는 size에 의해 제어."
        },
        "badge": {
          "type": "ReactNode",
          "description": "우측 뱃지/카운터. ml-auto로 우측 정렬."
        },
        "disabled": {
          "type": "boolean",
          "default": false,
          "description": "개별 비활성화."
        },
        "children": { "type": "ReactNode" },
        "className": { "type": "string" }
      }
    },
    {
      "name": "SideNavDivider",
      "role": "시각적 구분선.",
      "element": "hr",
      "props": {
        "className": { "type": "string" }
      }
    },
    {
      "name": "SideNavPanel",
      "role": "SideNavItem에 연결되는 콘텐츠 영역 (vertical tab 용도). value가 일치할 때만 렌더링.",
      "element": "div[role=tabpanel]",
      "props": {
        "value": {
          "type": "string",
          "description": "연결된 SideNavItem의 value와 일치."
        },
        "forceMount": {
          "type": "boolean",
          "default": false,
          "description": "비활성 패널을 DOM에 유지할지 여부."
        },
        "children": { "type": "ReactNode" },
        "className": { "type": "string" }
      }
    }
  ],

  "context": {
    "name": "SideNavContext",
    "sharedState": {
      "value": "현재 선택된 아이템의 value",
      "onChange": "선택 변경 핸들러",
      "size": "large | medium | small",
      "disabled": "전체 비활성화 여부"
    }
  },

  "variants": {
    "size": {
      "large": {
        "itemHeight": "44px",
        "itemPaddingX": "var(--spacing-3) = 12px",
        "itemGap": "var(--spacing-2) = 8px",
        "itemRadius": "var(--radius-2) = 8px",
        "iconSize": "20px",
        "typography": "typography-15-semibold",
        "typographyActive": "typography-15-semibold",
        "typographyGroup": "typography-10-semibold"
      },
      "medium": {
        "itemHeight": "36px",
        "itemPaddingX": "var(--spacing-3) = 12px",
        "itemGap": "var(--spacing-1.5) = 6px",
        "itemRadius": "var(--radius-1.5) = 6px",
        "iconSize": "18px",
        "typography": "typography-14-semibold",
        "typographyActive": "typography-14-semibold",
        "typographyGroup": "typography-10-semibold"
      },
      "small": {
        "itemHeight": "32px",
        "itemPaddingX": "var(--spacing-2.5) = 10px",
        "itemGap": "var(--spacing-1.5) = 6px",
        "itemRadius": "var(--radius-1.5) = 6px",
        "iconSize": "16px",
        "typography": "typography-13-semibold",
        "typographyActive": "typography-13-semibold",
        "typographyGroup": "typography-10-semibold"
      }
    }
  },

  "states": {
    "default": {
      "text": "var(--comp-sidenav-text) → text-on-bright-500",
      "bg": "transparent"
    },
    "active": {
      "text": "var(--comp-sidenav-text-active) → text-on-bright-900",
      "bg": "var(--comp-sidenav-bg-active) → state-on-bright-100"
    },
    "hover": {
      "bg": "var(--comp-sidenav-hover) → state-on-bright-70",
      "condition": "!disabled && !active"
    },
    "pressed": {
      "bg": "var(--comp-sidenav-active) → state-on-bright-100",
      "condition": "!disabled && !active"
    },
    "disabled": {
      "text": "var(--comp-sidenav-text-disabled) → text-on-bright-400",
      "cursor": "cursor-not-allowed"
    },
    "focus": {
      "all": "focus-visible:ring-2 ring-[var(--comp-sidenav-focus-ring)] ring-offset-2 → primary-300"
    },
    "groupHeader": {
      "text": "var(--comp-sidenav-group-text) → text-on-bright-400",
      "hover": "collapsible일 때 bg-[var(--comp-sidenav-hover)]"
    }
  },

  "tokens": {
    "sizeTokens": {
      "scope": ":root",
      "pattern": "--comp-sidenav-{property}-{size}",
      "list": [
        "--comp-sidenav-item-height-lg: 44px",
        "--comp-sidenav-item-height-md: 36px",
        "--comp-sidenav-item-height-sm: 32px",
        "--comp-sidenav-item-px-lg: var(--spacing-3) = 12px",
        "--comp-sidenav-item-px-md: var(--spacing-3) = 12px",
        "--comp-sidenav-item-px-sm: var(--spacing-2.5) = 10px",
        "--comp-sidenav-item-gap-lg: var(--spacing-2) = 8px",
        "--comp-sidenav-item-gap-md: var(--spacing-1.5) = 6px",
        "--comp-sidenav-item-gap-sm: var(--spacing-1.5) = 6px",
        "--comp-sidenav-item-radius-lg: var(--radius-2) = 8px",
        "--comp-sidenav-item-radius-md: var(--radius-1.5) = 6px",
        "--comp-sidenav-item-radius-sm: var(--radius-1.5) = 6px",
        "--comp-sidenav-icon-lg: 20px",
        "--comp-sidenav-icon-md: 18px",
        "--comp-sidenav-icon-sm: 16px"
      ]
    },
    "colorTokens": {
      "scope": "[data-theme]",
      "pattern": "--comp-sidenav-{property}[-{state}]",
      "list": [
        "--comp-sidenav-text: text-on-bright-500",
        "--comp-sidenav-text-active: text-on-bright-900",
        "--comp-sidenav-text-disabled: text-on-bright-400",
        "--comp-sidenav-group-text: text-on-bright-400",
        "--comp-sidenav-bg-active: state-on-bright-100",
        "--comp-sidenav-hover: state-on-bright-70",
        "--comp-sidenav-active: state-on-bright-100",
        "--comp-sidenav-focus-ring: primary-300",
        "--comp-sidenav-divider: divider-solid-100"
      ]
    },
    "geoShapeOverrides": []
  },

  "features": {
    "collapsibleGroups": {
      "description": "SideNavGroup은 접기/펼치기를 지원. grid transition으로 부드러운 높이 애니메이션.",
      "mechanism": "CSS grid-template-rows transition: expanded=grid-rows-[1fr], collapsed=grid-rows-[0fr]. overflow-hidden.",
      "transition": "transition-[grid-template-rows] duration-normal ease-move",
      "chevron": "우측 chevron 아이콘, expanded 시 rotate-90. transition-transform duration-fast ease-move."
    },
    "groupHeaderStyling": {
      "typography": "typography-10-semibold, uppercase, tracking-wider",
      "color": "var(--comp-sidenav-group-text)",
      "hover": "collapsible일 때만 hover bg 적용"
    },
    "badgeSlot": {
      "description": "SideNavItem의 badge prop은 우측에 ml-auto로 배치.",
      "styling": "flex-shrink-0 ml-auto"
    },
    "panelPattern": {
      "description": "SideNavPanel로 vertical tab 패턴 구현 가능. value 기반 조건부 렌더링 또는 forceMount+hidden.",
      "aria": "role=tabpanel, aria-labelledby=sidenav-item-{value}"
    }
  },

  "accessibility": {
    "landmark": "nav element",
    "attributes": {
      "aria-current": "active 아이템에 aria-current='page'",
      "aria-disabled": "비활성 아이템에 설정 (포커스 유지)",
      "aria-expanded": "collapsible 그룹 헤더에 설정"
    },
    "panelAttributes": {
      "role": "tabpanel",
      "aria-labelledby": "sidenav-item-{value}",
      "tabIndex": 0
    },
    "listStructure": "SideNavItem은 <li> 내부의 <button>. SideNavGroup content는 <ul>."
  },

  "implementation": {
    "pattern": "Compound Component + Context + CVA + cn",
    "stateOverlay": "SideNavItem은 직접 hover/active bg 적용 (hover:bg-[...], active:bg-[...]), state overlay 패턴 미사용",
    "collapseAnimation": "CSS grid transition — grid-rows-[1fr] ↔ grid-rows-[0fr] + overflow-hidden",
    "files": [
      "src/components/SideNav/SideNav.tsx",
      "src/components/SideNav/index.ts"
    ],
    "dependencies": [],
    "variantMetadata": {
      "SIDENAV_SIZES": ["large", "medium", "small"]
    },
    "exportedTypes": [
      "SideNavProps",
      "SideNavGroupProps",
      "SideNavItemProps",
      "SideNavDividerProps",
      "SideNavPanelProps",
      "SideNavSize"
    ]
  }
}
