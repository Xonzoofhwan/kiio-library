{
  "component": "Textarea",
  "description": "Multi-line text input with integrated label, helper text, counter, and validation states. Supports 2 sizes with variable height based on rows.",
  "figmaNode": "7327:29353",

  "props": {
    "size": {
      "type": "'xLarge' | 'large'",
      "default": "large"
    },
    "validation": {
      "type": "'default' | 'error' | 'success'",
      "default": "default",
      "description": "Validation state. Controls border color when focused and helper text style."
    },
    "label": {
      "type": "string",
      "default": null,
      "description": "Label text displayed above the textarea."
    },
    "labelType": {
      "type": "'none' | 'optional' | 'asterisk'",
      "default": "none",
      "description": "Label suffix indicator. Same as Input."
    },
    "placeholder": {
      "type": "string",
      "default": null
    },
    "helperText": {
      "type": "string",
      "default": null,
      "description": "Helper text below the textarea. Switches to error/success style based on validation prop."
    },
    "counter": {
      "type": "boolean",
      "default": false,
      "description": "Shows character counter (currentLength/maxLength). Requires maxLength prop."
    },
    "maxLength": {
      "type": "number",
      "default": null,
      "description": "Maximum character count. Used with counter for display and validation."
    },
    "rows": {
      "type": "number",
      "default": 3,
      "description": "Number of visible text lines. Determines initial height."
    },
    "resize": {
      "type": "'none' | 'vertical' | 'both'",
      "default": "vertical",
      "description": "CSS resize behavior."
    },
    "iconTrailing": {
      "type": "ReactNode",
      "default": null,
      "description": "Trailing icon in the textarea header area."
    },
    "disabled": {
      "type": "boolean",
      "default": false,
      "description": "Inactive state. Prevents interaction."
    },
    "readOnly": {
      "type": "boolean",
      "default": false,
      "description": "Read-only state. Content visible but not editable."
    },
    "fullWidth": {
      "type": "boolean",
      "default": false,
      "description": "Hug (false) or Fill (true)"
    }
  },

