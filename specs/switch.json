  "implementation": {
    "pattern": "Record maps + cn() (NOT CVA — see _pattern_note)",
    "_pattern_note": "Multi-axis variants (shape × size = 8 combos × multiple properties) are expressed as nested Record<Shape, Record<Size, string>> maps for clarity. CVA's compoundVariants would be more verbose for this case.",
    "library": "@radix-ui/react-switch",
    "structure": [
      "RadixSwitch.Root (the track) — group, data-state, focus-visible target",
      "  └ <span> state overlay (sibling to Thumb, hover/press tint)",
      "  └ <span> focus ring (sibling, 2px inset border)",
      "  └ RadixSwitch.Thumb (the placer) — slides Off → On via translate-x",
      "       └ <span> knob (visual layer) — squeeze (circular) or inset slide (square)"
    ],
    "stateDriving": "Radix sets data-state=checked|unchecked + data-disabled on Root and Thumb. Combined with :hover / :active / :focus-visible via Tailwind group selectors and arbitrary parent selectors like 'group-[[data-state=checked]:not(:hover):not(:active)]' to ensure unambiguous specificity.",
    "transitions": {
      "trackBg": "transition-colors duration-fast ease-enter",
      "thumbPosition": "transition-transform duration-normal ease-move (Radix Thumb slide)",
      "circularKnobSqueeze": "transition-[width,height,background-color] duration-fast ease-enter",
      "squareKnobInsetSlide": "transition-[transform,background-color] duration-fast ease-enter",
      "stateOverlay": "transition-colors duration-fast ease-enter",
      "focusRing": "transition-opacity duration-fast ease-enter"
    },
    "knobInteractionLogic": {
      "circular": {
        "model": "2-tier size — 'expanded' (full placer) vs 'compact' (~4-8px smaller)",
        "rule": "compact by default; expand only when ON + not :hover + not :active",
        "selector": "group-[[data-state=checked]:not(:hover):not(:active)]:size-{expanded}"
      },
      "square": {
        "model": "Fixed knob size; translate-x changes based on (state, hover) combination",
        "positions": {
          "off-default": "translate-x: 0 (knob at left edge of placer)",
          "off-hover": "translate-x: +inset (2px, slide right)",
          "on-default": "translate-x: +edge (4px = placer−knob, knob at right edge)",
          "on-hover": "translate-x: +inset (2px, slide left from edge — hover always centers)"
        }
      }
    },
