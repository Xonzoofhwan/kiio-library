{
  "component": "Switch",
  "description": "Accessible toggle switch with smooth slide animation. Built on @radix-ui/react-switch. Always uses pill radius regardless of shape theme.",

  "props": {
    "size": {
      "type": "'large' | 'medium' | 'small'",
      "default": "medium"
    },
    "checked": {
      "type": "boolean",
      "default": false,
      "description": "Controlled checked state."
    },
    "defaultChecked": {
      "type": "boolean",
      "default": false,
      "description": "Uncontrolled default checked state."
    },
    "onCheckedChange": {
      "type": "(checked: boolean) => void",
      "default": null
    },
    "label": {
      "type": "string",
      "default": null,
      "description": "Label text displayed next to the switch."
    },
    "disabled": {
      "type": "boolean",
      "default": false
    },
    "required": {
      "type": "boolean",
      "default": false
    },
    "name": {
      "type": "string",
      "default": null
    },
    "value": {
      "type": "string",
      "default": "on"
    }
  },

  "variants": {
    "size": {
      "large": {
        "trackWidth": "w-11 (44px)",
        "trackHeight": "h-6 (24px)",
        "thumbSize": "size-5 (20px)",
        "thumbOffset": "2px",
        "thumbTranslate": "translateX(20px)",
        "labelTypography": "typography-16-regular",
        "gap": "gap-2.5 (10px)"
      },
      "medium": {
        "trackWidth": "w-9 (36px)",
        "trackHeight": "h-5 (20px)",
        "thumbSize": "size-4 (16px)",
        "thumbOffset": "2px",
        "thumbTranslate": "translateX(16px)",
        "labelTypography": "typography-14-regular",
        "gap": "gap-2 (8px)"
      },
      "small": {
        "trackWidth": "w-7 (28px)",
        "trackHeight": "h-4 (16px)",
        "thumbSize": "size-3 (12px)",
        "thumbOffset": "2px",
        "thumbTranslate": "translateX(12px)",
        "labelTypography": "typography-13-regular",
        "gap": "gap-1.5 (6px)"
      }
    }
  },

  "states": {
    "off": {
      "track": "bg-sys-neutral-black-alpha-200",
      "thumb": "bg-sys-neutral-solid-0"
    },
    "on": {
      "track": "bg-sys-neutral-solid-950",
      "thumb": "bg-sys-neutral-solid-0"
    },
    "hover": {
      "off": "track: bg-sys-neutral-black-alpha-300",
      "on": "state overlay: sys-state-on-dim-50 on track"
    },
    "focused": {
      "all": "ring-2 ring-sys-primary-300 ring-offset-2 (focus-visible only)"
    },
    "disabled": {
      "off": {
        "track": "bg-sys-neutral-black-alpha-100",
        "thumb": "bg-sys-neutral-solid-0"
      },
      "on": {
        "track": "bg-sys-neutral-solid-300",
        "thumb": "bg-sys-neutral-white-alpha-400"
      },
      "label": "text-sys-neutral-black-alpha-200"
    }
  },

  "implementation": {
    "pattern": "CVA + cn + @radix-ui/react-switch",
    "structure": "Wrapper (flex, gap) → Switch.Root (styled track) → Switch.Thumb (styled circle) + Label",
    "thumbAnimation": "translateX transition with duration-fast ease-move. Thumb slides from left (off) to right (on).",
    "geoNote": "Switch is always pill (rounded-full) for both track and thumb. No geo radius override needed.",
    "files": [
      "src/components/Switch/Switch.tsx",
      "src/components/Switch/index.ts"
    ],
    "dependencies": [
      "@radix-ui/react-switch"
    ]
  }
}
