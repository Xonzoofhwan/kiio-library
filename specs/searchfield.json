{
  "component": "SearchField",
  "description": "TextField를 감싸는 검색 전용 입력 컴포넌트. 검색 아이콘, clear 버튼, Enter 제출을 기본 제공하고, loading 상태를 지원한다.",
  "pattern": "Composition wrapper over TextField",
  "base": "TextField",
  "props": {
    "onSearch": {
      "type": "(value: string) => void",
      "description": "Enter 키 제출 시 호출. 현재 입력값을 인자로 전달."
    },
    "searchIcon": {
      "type": "ReactNode",
      "default": "내장 돋보기 아이콘",
      "description": "검색 아이콘 커스텀."
    },
    "loading": {
      "type": "boolean",
      "default": false,
      "description": "검색 진행 중 상태. 아이콘을 Spinner로 교체."
    },
    "clearable": {
      "type": "boolean",
      "default": true,
      "description": "Clear 버튼 표시 (TextField 기본값 false를 true로 오버라이드)."
    },
    "placeholder": {
      "type": "string",
      "default": "검색",
      "description": "플레이스홀더 텍스트."
    }
  },
  "omittedFromBase": {
    "type": "항상 'search'로 고정",
    "startEnhancer": "검색 아이콘/Spinner가 자동 배치"
  },
  "inheritedFromBase": [
    "size (xSmall | small | medium | large | xLarge)",
    "error",
    "positive",
    "disabled",
    "readOnly",
    "clearOnEscape",
    "endEnhancer",
    "fullWidth",
    "onClear",
    "FormField Context integration"
  ],
  "tokens": "없음 — --comp-textfield-* 토큰 전부 재사용",
  "accessibility": {
    "landmark": "role='search' wrapper",
    "loading": "aria-busy='true' when loading",
    "inherited": "aria-invalid, aria-disabled, aria-required from TextField/FormField"
  },
  "implementation": {
    "files": [
      "src/components/SearchField/SearchField.tsx",
      "src/components/SearchField/index.ts"
    ],
    "dependencies": [
      "src/components/TextField/TextField.tsx",
      "src/components/icons/Spinner.tsx"
    ]
  },
  "futurePhase": {
    "autocomplete": "Phase 2 — @radix-ui/react-popover + --comp-dropdown-* 토큰 재활용"
  }
}
