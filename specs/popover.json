{
  "component": "Popover",
  "description": "트리거에 앵커된 범용 콘텐츠 컨테이너. Radix Popover 기반. DropdownMenu 스타일(bg, border, shadow, radius)을 따르되 자유 형태 children을 지원한다. click-outside/Escape 닫기.",
  "classification": "Compound (overlay, interactive, Radix-based)",

  "subComponents": [
    { "name": "Popover", "description": "Root. Radix Popover.Root + Theme Context.", "element": "n/a" },
    { "name": "PopoverTrigger", "description": "트리거. Radix Popover.Trigger + ref 저장.", "element": "button" },
    { "name": "PopoverContent", "description": "Portal + 콘텐츠 컨테이너.", "element": "div" },
    { "name": "PopoverArrow", "description": "선택적 화살표.", "element": "svg" },
    { "name": "PopoverClose", "description": "선택적 닫기 버튼.", "element": "button" }
  ],

  "props": {
    "Popover": {
      "open": { "type": "boolean", "description": "제어 모드 열림 상태." },
      "onOpenChange": { "type": "(open: boolean) => void" },
      "defaultOpen": { "type": "boolean", "default": false },
      "modal": { "type": "boolean", "default": false }
    },
    "PopoverTrigger": {
      "asChild": { "type": "boolean", "default": true }
    },
    "PopoverContent": {
      "side": { "type": "'top' | 'bottom' | 'left' | 'right'", "default": "bottom", "metadataArray": "POPOVER_SIDES" },
      "align": { "type": "'start' | 'center' | 'end'", "default": "center", "metadataArray": "POPOVER_ALIGNS" },
      "sideOffset": { "type": "number", "default": 8 },
      "showArrow": { "type": "boolean", "default": false }
    }
  },

  "variants": {
    "note": "단일 스타일. DropdownMenu 계열. variant/size 축 없음."
  },

  "states": {
    "open": "animate dropdown-enter",
    "closed": "animate dropdown-exit"
  },

  "tokens": {
    "sizeSpacing": {
      "layer": ":root",
      "list": [
        "--comp-popover-radius: var(--radius-3)",
        "--comp-popover-padding-x: var(--spacing-4)",
        "--comp-popover-padding-y: var(--spacing-3)",
        "--comp-popover-arrow-width: 16px",
        "--comp-popover-arrow-height: 8px"
      ]
    },
    "color": {
      "layer": "[data-theme]",
      "list": [
        "--comp-popover-bg: var(--semantic-background-0)",
        "--comp-popover-border: var(--semantic-divider-solid-100)",
        "--comp-popover-shadow: 0px 1px 4px rgba(0,0,0,0.04), 0px 4px 24px rgba(0,0,0,0.12)",
        "--comp-popover-arrow: var(--semantic-background-0)"
      ]
    }
  },

  "implementation": {
    "pattern": "Compound + Radix + cn",
    "radixPackage": "@radix-ui/react-popover (already installed for Callout)",
    "themeInheritance": "DropdownMenu와 동일한 Theme Context + triggerRef.closest('[data-theme]') 패턴",
    "animation": "기존 dropdown-enter/exit keyframes 재활용 (src/index.css)",
    "files": [
      "src/components/Popover/Popover.tsx",
      "src/components/Popover/index.ts"
    ],
    "dependencies": ["@radix-ui/react-popover"],
    "exports": {
      "components": ["Popover", "PopoverTrigger", "PopoverContent", "PopoverArrow", "PopoverClose"],
      "types": ["PopoverProps", "PopoverTriggerProps", "PopoverContentProps", "PopoverArrowProps", "PopoverCloseProps", "PopoverSide", "PopoverAlign"],
      "metadata": ["POPOVER_SIDES", "POPOVER_ALIGNS"]
    }
  }
}
