{
  "component": "Accordion",
  "description": "접이식 콘텐츠 섹션 컴포넌트. Radix Accordion 기반. single/multiple 열기 모드, 3가지 시각 variant, 3가지 크기를 지원한다.",
  "classification": "Compound (interactive, Radix-based)",

  "subComponents": [
    {
      "name": "Accordion",
      "description": "Root wrapper. Radix Accordion.Root. type + variant + size Context 제공.",
      "element": "div"
    },
    {
      "name": "AccordionItem",
      "description": "개별 섹션 wrapper. Radix Accordion.Item.",
      "element": "div"
    },
    {
      "name": "AccordionTrigger",
      "description": "헤더 (클릭 영역). Chevron 자동 회전. Radix Accordion.Trigger.",
      "element": "button"
    },
    {
      "name": "AccordionContent",
      "description": "접히는 콘텐츠 영역. height 0→auto 애니메이션. Radix Accordion.Content.",
      "element": "div"
    }
  ],

  "props": {
    "Accordion": {
      "type": {
        "type": "'single' | 'multiple'",
        "default": "single",
        "description": "single: 하나만 열림. multiple: 여러 개 동시 열림.",
        "metadataArray": "ACCORDION_TYPES"
      },
      "variant": {
        "type": "'default' | 'outlined' | 'separated'",
        "default": "default",
        "description": "default: border-bottom 리스트. outlined: 전체 border 카드. separated: 개별 카드+gap.",
        "metadataArray": "ACCORDION_VARIANTS"
      },
      "size": {
        "type": "'small' | 'medium' | 'large'",
        "default": "medium",
        "metadataArray": "ACCORDION_SIZES"
      },
      "collapsible": {
        "type": "boolean",
        "default": true,
        "description": "single 모드에서 열린 항목을 다시 닫을 수 있는지."
      },
      "value": { "type": "string | string[]", "description": "제어 모드 값." },
      "onValueChange": { "type": "(value: string | string[]) => void" },
      "defaultValue": { "type": "string | string[]" },
      "disabled": { "type": "boolean", "default": false }
    },
    "AccordionItem": {
      "value": { "type": "string", "description": "항목 고유 식별자. 필수." },
      "disabled": { "type": "boolean", "default": false }
    },
    "AccordionTrigger": {
      "children": { "type": "ReactNode", "description": "헤더 텍스트/콘텐츠." }
    },
    "AccordionContent": {
      "children": { "type": "ReactNode", "description": "접히는 콘텐츠." }
    }
  },

  "variants": {
    "size": {
      "small": {
        "triggerPy": "10px",
        "triggerPx": "12px",
        "triggerTypography": "typography-14-medium",
        "contentPadding": "12px",
        "chevronSize": "16px"
      },
      "medium": {
        "triggerPy": "14px",
        "triggerPx": "16px",
        "triggerTypography": "typography-15-medium",
        "contentPadding": "16px",
        "chevronSize": "18px"
      },
      "large": {
        "triggerPy": "18px",
        "triggerPx": "20px",
        "triggerTypography": "typography-16-medium",
        "contentPadding": "20px",
        "chevronSize": "20px"
      }
    },
    "variant": {
      "default": "border-bottom only, flat list",
      "outlined": "full border + radius, single card wrapping all items",
      "separated": "each item is individual card with gap between"
    }
  },

  "states": {
    "collapsed": { "trigger": "transparent bg", "border": "divider-solid-100", "chevron": "0deg" },
    "expanded": { "trigger": "transparent bg", "border": "divider-solid-100", "chevron": "180deg" },
    "hover": { "trigger": "state-on-bright-50 overlay" },
    "focused": { "trigger": "focus-visible ring-2 ring-primary-300 ring-offset-2" },
    "disabled": { "trigger": "text-on-bright-400, chevron hidden, no interaction" }
  },

  "tokens": {
    "sizeSpacing": {
      "layer": ":root",
      "list": [
        "--comp-accordion-trigger-py-sm: 10px",
        "--comp-accordion-trigger-py-md: 14px",
        "--comp-accordion-trigger-py-lg: 18px",
        "--comp-accordion-trigger-px-sm: var(--spacing-3)",
        "--comp-accordion-trigger-px-md: var(--spacing-4)",
        "--comp-accordion-trigger-px-lg: var(--spacing-5)",
        "--comp-accordion-content-padding-sm: var(--spacing-3)",
        "--comp-accordion-content-padding-md: var(--spacing-4)",
        "--comp-accordion-content-padding-lg: var(--spacing-5)",
        "--comp-accordion-chevron-sm: 16px",
        "--comp-accordion-chevron-md: 18px",
        "--comp-accordion-chevron-lg: 20px",
        "--comp-accordion-radius: var(--radius-2)",
        "--comp-accordion-separated-gap: var(--spacing-2)"
      ]
    },
    "color": {
      "layer": "[data-theme]",
      "list": [
        "--comp-accordion-border: var(--semantic-divider-solid-100)",
        "--comp-accordion-trigger-text: var(--semantic-text-on-bright-900)",
        "--comp-accordion-trigger-hover: var(--semantic-state-on-bright-50)",
        "--comp-accordion-chevron: var(--semantic-text-on-bright-500)",
        "--comp-accordion-content-text: var(--semantic-text-on-bright-700)",
        "--comp-accordion-disabled-text: var(--semantic-text-on-bright-400)",
        "--comp-accordion-focus-ring: var(--semantic-primary-300)"
      ]
    }
  },

  "implementation": {
    "pattern": "Compound + Radix + cn",
    "radixPackage": "@radix-ui/react-accordion",
    "context": "AccordionContext: { variant, size }",
    "animation": {
      "chevron": "transition-transform duration-normal ease-move, data-[state=open]:rotate-180",
      "content": "CSS keyframes via Radix data-state: animate-accordion-down (open), animate-accordion-up (closed). Uses --radix-accordion-content-height."
    },
    "files": [
      "src/components/Accordion/Accordion.tsx",
      "src/components/Accordion/index.ts"
    ],
    "dependencies": ["@radix-ui/react-accordion"],
    "exports": {
      "components": ["Accordion", "AccordionItem", "AccordionTrigger", "AccordionContent"],
      "types": ["AccordionProps", "AccordionItemProps", "AccordionTriggerProps", "AccordionContentProps", "AccordionType", "AccordionVariant", "AccordionSize"],
      "metadata": ["ACCORDION_TYPES", "ACCORDION_VARIANTS", "ACCORDION_SIZES"]
    }
  }
}
