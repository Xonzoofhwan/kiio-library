{
  "component": "RadioGroup",
  "description": "리스트형 상호 배타적 선택 컴포넌트. Radix RadioGroup 기반. 라벨+설명 텍스트 지원, FormField 통합. SegmentBar(토글 버튼)와 달리 폼 데이터 제출용 리스트 선택.",
  "classification": "Compound (form, interactive, Radix-based)",

  "subComponents": [
    {
      "name": "RadioGroup",
      "description": "Root wrapper. Radix RadioGroup.Root + Context(size, orientation, disabled).",
      "element": "div[role=radiogroup]"
    },
    {
      "name": "RadioGroupItem",
      "description": "개별 라디오 항목. 원형 인디케이터 + 라벨 + 선택적 설명 텍스트.",
      "element": "label > Radix RadioGroup.Item"
    }
  ],

  "props": {
    "RadioGroup": {
      "value": { "type": "string", "description": "선택된 항목의 value." },
      "onValueChange": { "type": "(value: string) => void", "description": "값 변경 콜백." },
      "defaultValue": { "type": "string", "description": "비제어 모드 기본값." },
      "size": {
        "type": "'medium' | 'large'",
        "default": "medium",
        "metadataArray": "RADIO_GROUP_SIZES"
      },
      "orientation": {
        "type": "'vertical' | 'horizontal'",
        "default": "vertical",
        "metadataArray": "RADIO_GROUP_ORIENTATIONS"
      },
      "disabled": { "type": "boolean", "default": false },
      "name": { "type": "string", "description": "폼 필드 name." }
    },
    "RadioGroupItem": {
      "value": { "type": "string", "description": "항목 고유값. 필수." },
      "label": { "type": "string", "description": "라벨 텍스트." },
      "description": { "type": "string", "description": "보조 설명 텍스트." },
      "disabled": { "type": "boolean", "default": false }
    }
  },

  "variants": {
    "size": {
      "medium": {
        "radioSize": "20px",
        "dotSize": "8px",
        "gap": "8px (spacing-2)",
        "itemGap": "12px (spacing-3)",
        "labelTypography": "typography-14-medium",
        "descriptionTypography": "typography-13-regular"
      },
      "large": {
        "radioSize": "24px",
        "dotSize": "10px",
        "gap": "10px (spacing-2.5)",
        "itemGap": "16px (spacing-4)",
        "labelTypography": "typography-16-medium",
        "descriptionTypography": "typography-14-regular"
      }
    }
  },

  "states": {
    "unchecked": {
      "border": "neutral-solid-300",
      "bg": "background-0",
      "dot": "none"
    },
    "checked": {
      "border": "primary-500",
      "bg": "primary-500",
      "dot": "neutral-0 (white)"
    },
    "hover": {
      "border": "neutral-solid-400 (unchecked) / primary-600 (checked)",
      "overlay": "state-on-bright-50"
    },
    "focused": {
      "ring": "focus-visible ring-2 ring-primary-300 ring-offset-2"
    },
    "disabled": {
      "border": "neutral-solid-200",
      "bg": "neutral-solid-50 (unchecked) / neutral-solid-300 (checked)",
      "dot": "neutral-solid-0 (checked)",
      "label": "text-on-bright-400",
      "cursor": "not-allowed"
    }
  },

  "tokens": {
    "sizeSpacing": {
      "layer": ":root",
      "list": [
        "--comp-radio-size-md: 20px",
        "--comp-radio-size-lg: 24px",
        "--comp-radio-dot-md: 8px",
        "--comp-radio-dot-lg: 10px",
        "--comp-radio-gap-md: var(--spacing-2)",
        "--comp-radio-gap-lg: var(--spacing-2.5)",
        "--comp-radio-item-gap-md: var(--spacing-3)",
        "--comp-radio-item-gap-lg: var(--spacing-4)"
      ]
    },
    "color": {
      "layer": "[data-theme]",
      "list": [
        "--comp-radio-border: var(--semantic-neutral-solid-300)",
        "--comp-radio-border-hover: var(--semantic-neutral-solid-400)",
        "--comp-radio-border-checked: var(--semantic-primary-500)",
        "--comp-radio-border-checked-hover: var(--semantic-primary-600)",
        "--comp-radio-bg-checked: var(--semantic-primary-500)",
        "--comp-radio-dot: var(--semantic-neutral-solid-0)",
        "--comp-radio-border-disabled: var(--semantic-neutral-solid-200)",
        "--comp-radio-bg-disabled: var(--semantic-neutral-solid-50)",
        "--comp-radio-bg-checked-disabled: var(--semantic-neutral-solid-300)",
        "--comp-radio-label: var(--semantic-text-on-bright-900)",
        "--comp-radio-description: var(--semantic-text-on-bright-600)",
        "--comp-radio-label-disabled: var(--semantic-text-on-bright-400)",
        "--comp-radio-focus-ring: var(--semantic-primary-300)"
      ]
    }
  },

  "implementation": {
    "pattern": "Compound + Radix + cn",
    "radixPackage": "@radix-ui/react-radio-group",
    "context": "RadioGroupContext: { size, disabled }",
    "formFieldIntegration": "Reads FormField context for disabled, name, error states (optional)",
    "accessibility": "Radix handles role=radiogroup, aria-checked, arrow key navigation, auto-select",
    "files": [
      "src/components/RadioGroup/RadioGroup.tsx",
      "src/components/RadioGroup/index.ts"
    ],
    "dependencies": ["@radix-ui/react-radio-group"],
    "exports": {
      "components": ["RadioGroup", "RadioGroupItem"],
      "types": ["RadioGroupProps", "RadioGroupItemProps", "RadioGroupSize", "RadioGroupOrientation"],
      "metadata": ["RADIO_GROUP_SIZES", "RADIO_GROUP_ORIENTATIONS"]
    }
  }
}
