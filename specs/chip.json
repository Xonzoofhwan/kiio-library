{
  "component": "Chip",
  "description": "Interactive chip system with 3 sub-components: ChipTag (removable value), ChipFilter (toggleable filter), ChipDropdown (menu trigger with badge count). All share common size tokens but each has its own CVA, color maps, and interaction model. Always pill-shaped (rounded-full).",
  "classification": "Primitive (multi-variant, 3 sub-components)",

  "subComponents": [
    {
      "name": "ChipTag",
      "description": "Displays a value with a remove button. Non-toggle — always 'on' until removed. Has label + close icon.",
      "element": "div (role='group')",
      "props": {
        "label": {
          "type": "string",
          "description": "Display text."
        },
        "onRemove": {
          "type": "() => void",
          "description": "Remove callback. Called when close button is clicked."
        },
        "size": {
          "type": "'small' | 'medium' | 'large'",
          "default": "medium",
          "description": "Size variant. Controls height, padding, gap, typography, icon size.",
          "metadataArray": "CHIP_SIZES"
        },
        "intent": {
          "type": "'grayscale' | 'error'",
          "default": "grayscale",
          "description": "Color intent.",
          "metadataArray": "CHIP_TAG_INTENTS"
        },
        "disabled": {
          "type": "boolean",
          "default": false,
          "description": "Disables remove interaction."
        }
      },
      "variants": {
        "intent": {
          "grayscale": {
            "bg": "--comp-chip-tag-bg → semantic-neutral-solid-100",
            "label": "--comp-chip-tag-label → semantic-neutral-solid-900",
            "removeIcon": "--comp-chip-tag-remove → semantic-neutral-solid-600"
          },
          "error": {
            "bg": "--comp-chip-tag-bg-error → semantic-error-50",
            "label": "--comp-chip-tag-label-error → semantic-error-700",
            "removeIcon": "--comp-chip-tag-remove-error → semantic-error-500"
          }
        }
      },
      "states": {
        "hover": "State overlay: --comp-chip-state-hover-on-bright (always on-bright — Tag has no 'on' dark state)",
        "pressed": "State overlay: --comp-chip-state-pressed-on-bright",
        "disabled": {
          "bg": "--comp-chip-tag-bg-disabled → semantic-neutral-solid-70",
          "label": "--comp-chip-tag-label-disabled → semantic-neutral-solid-400",
          "removeIcon": "--comp-chip-tag-remove-disabled → semantic-neutral-solid-300",
          "behavior": "cursor-not-allowed, no overlay, remove button pointer-events-none, tabIndex -1"
        },
        "focus": "Remove button: focus-visible ring-2, ring --comp-chip-focus-ring, ring-offset-1, rounded-full"
      }
    },
    {
      "name": "ChipFilter",
      "description": "Toggleable button for filtering lists. Has off (unselected) and on (selected) visual states. Optional leading icon.",
      "element": "button (type='button')",
      "props": {
        "label": {
          "type": "string",
          "description": "Display text."
        },
        "selected": {
          "type": "boolean",
          "description": "On/off state (controlled)."
        },
        "onToggle": {
          "type": "(next: boolean) => void",
          "description": "Toggle callback."
        },
        "leadingIcon": {
          "type": "ReactNode",
          "default": null,
          "description": "Optional leading icon. Sized by chip size variant."
        },
        "size": {
          "type": "'small' | 'medium' | 'large'",
          "default": "medium",
          "metadataArray": "CHIP_SIZES"
        },
        "intent": {
          "type": "'grayscale' | 'brand'",
          "default": "grayscale",
          "description": "Color intent for on-state container.",
          "metadataArray": "CHIP_FILTER_INTENTS"
        },
        "disabled": {
          "type": "boolean",
          "default": false
        }
      },
      "variants": {
        "intent × selected": {
          "off": {
            "bg": "--comp-chip-filter-bg-off → semantic-neutral-solid-70",
            "label": "--comp-chip-filter-label-off → semantic-neutral-solid-700"
          },
          "on-grayscale": {
            "bg": "--comp-chip-filter-bg-on → semantic-neutral-solid-950",
            "label": "--comp-chip-filter-label-on → semantic-neutral-solid-0"
          },
          "on-brand": {
            "bg": "--comp-chip-filter-bg-on-brand → semantic-primary-500",
            "label": "--comp-chip-filter-label-on-brand → semantic-neutral-solid-0"
          }
        }
      },
      "states": {
        "hover": {
          "off": "State overlay: --comp-chip-state-hover-on-bright",
          "on": "State overlay: --comp-chip-state-hover-on-dim"
        },
        "pressed": {
          "off": "State overlay: --comp-chip-state-pressed-on-bright",
          "on": "State overlay: --comp-chip-state-pressed-on-dim"
        },
        "disabled": {
          "off": {
            "bg": "--comp-chip-filter-bg-off-disabled → semantic-neutral-solid-70",
            "label": "--comp-chip-filter-label-disabled → semantic-neutral-solid-400"
          },
          "on": {
            "bg": "--comp-chip-filter-bg-on-disabled → semantic-neutral-solid-100",
            "label": "--comp-chip-filter-label-disabled → semantic-neutral-solid-400"
          },
          "behavior": "cursor-not-allowed, no overlay, aria-disabled, preventDefault on click"
        },
        "focus": "focus-visible ring-2, ring --comp-chip-focus-ring, ring-offset-2"
      },
      "accessibility": {
        "role": "button with aria-pressed",
        "disabled": "aria-disabled (not HTML disabled — preserves focus)"
      }
    },
    {
      "name": "ChipDropdown",
      "description": "Opens a menu/popover when clicked. Displays label, optional leading icon, trailing chevron, and overflow badge counter. Off/on determined by badgeCount.",
      "element": "button (type='button')",
      "props": {
        "label": {
          "type": "string",
          "description": "Display text."
        },
        "open": {
          "type": "boolean",
          "description": "Menu open state (controlled)."
        },
        "onOpenChange": {
          "type": "(next: boolean) => void",
          "description": "Open/close callback."
        },
        "leadingIcon": {
          "type": "ReactNode",
          "default": null,
          "description": "Optional leading icon."
        },
        "badgeCount": {
          "type": "number",
          "default": 0,
          "description": "Selected item count. 0 = off state (badge hidden), >= 1 = on state (badge shown). Capped at '99+' display."
        },
        "size": {
          "type": "'small' | 'medium' | 'large'",
          "default": "medium",
          "metadataArray": "CHIP_SIZES"
        },
        "intent": {
          "type": "'grayscale' | 'brand'",
          "default": "grayscale",
          "description": "Color intent for on-state container.",
          "metadataArray": "CHIP_DROPDOWN_INTENTS"
        },
        "disabled": {
          "type": "boolean",
          "default": false
        }
      },
      "variants": {
        "intent × hasSelection": {
          "off": {
            "bg": "--comp-chip-dropdown-bg-off → semantic-neutral-solid-70",
            "label": "--comp-chip-dropdown-label-off → semantic-neutral-solid-700"
          },
          "on-grayscale": {
            "bg": "--comp-chip-dropdown-bg-on → semantic-neutral-solid-950",
            "label": "--comp-chip-dropdown-label-on → semantic-neutral-solid-0"
          },
          "on-brand": {
            "bg": "--comp-chip-dropdown-bg-on-brand → semantic-primary-500",
            "label": "--comp-chip-dropdown-label-on-brand → semantic-neutral-solid-0"
          }
        },
        "badge": {
          "bg": "--comp-chip-dropdown-badge-bg → semantic-primary-500",
          "label": "--comp-chip-dropdown-badge-label → semantic-neutral-solid-0",
          "position": "absolute -top-1 -right-1, pointer-events-none",
          "component": "Uses BadgeCounter from Badge component"
        }
      },
      "states": {
        "hover": {
          "off": "State overlay: --comp-chip-state-hover-on-bright",
          "on": "State overlay: --comp-chip-state-hover-on-dim"
        },
        "pressed": {
          "off": "State overlay: --comp-chip-state-pressed-on-bright",
          "on": "State overlay: --comp-chip-state-pressed-on-dim"
        },
        "disabled": {
          "off": {
            "bg": "--comp-chip-dropdown-bg-off-disabled → semantic-neutral-solid-70",
            "label": "--comp-chip-dropdown-label-disabled → semantic-neutral-solid-400"
          },
          "on": {
            "bg": "--comp-chip-dropdown-bg-on-disabled → semantic-neutral-solid-100",
            "label": "--comp-chip-dropdown-label-disabled → semantic-neutral-solid-400"
          },
          "behavior": "cursor-not-allowed, no overlay, badge hidden, aria-disabled"
        },
        "focus": "focus-visible ring-2, ring --comp-chip-focus-ring, ring-offset-2"
      },
      "accessibility": {
        "role": "button with aria-haspopup='listbox' + aria-expanded",
        "disabled": "aria-disabled (not HTML disabled — preserves focus)"
      }
    }
  ],

  "sharedVariants": {
    "size": {
      "small": {
        "height": "--comp-chip-height-sm (24px)",
        "paddingX": "--comp-chip-padding-h-sm → spacing-1.5 (6px)",
        "gap": "--comp-chip-gap-sm → spacing-0.5 (2px)",
        "iconSize": "--comp-chip-icon-sm (16px)",
        "labelPaddingX": "--comp-chip-label-px-sm → spacing-0.5 (2px)",
        "typography": "typography-12-medium"
      },
      "medium": {
        "height": "--comp-chip-height-md → spacing-8 (32px)",
        "paddingX": "--comp-chip-padding-h-md → spacing-2 (8px)",
        "gap": "--comp-chip-gap-md → spacing-0.5 (2px)",
        "iconSize": "--comp-chip-icon-md (18px)",
        "labelPaddingX": "--comp-chip-label-px-md → spacing-1 (4px)",
        "typography": "typography-13-medium"
      },
      "large": {
        "height": "--comp-chip-height-lg → spacing-10 (40px)",
        "paddingX": "--comp-chip-padding-h-lg → spacing-2.5 (10px)",
        "gap": "--comp-chip-gap-lg → spacing-1 (4px)",
        "iconSize": "--comp-chip-icon-lg → spacing-5 (20px)",
        "labelPaddingX": "--comp-chip-label-px-lg → spacing-1 (4px)",
        "typography": "typography-15-medium"
      }
    }
  },

  "tokens": {
    "sizeSpacing": {
      "layer": ":root",
      "naming": "--comp-chip-{property}-{size}",
      "list": [
        "--comp-chip-height-sm: 24px",
        "--comp-chip-height-md: var(--spacing-8) (32px)",
        "--comp-chip-height-lg: var(--spacing-10) (40px)",
        "--comp-chip-padding-h-sm: var(--spacing-1.5) (6px)",
        "--comp-chip-padding-h-md: var(--spacing-2) (8px)",
        "--comp-chip-padding-h-lg: var(--spacing-2.5) (10px)",
        "--comp-chip-gap-sm: var(--spacing-0.5) (2px)",
        "--comp-chip-gap-md: var(--spacing-0.5) (2px)",
        "--comp-chip-gap-lg: var(--spacing-1) (4px)",
        "--comp-chip-icon-sm: 16px",
        "--comp-chip-icon-md: 18px",
        "--comp-chip-icon-lg: var(--spacing-5) (20px)",
        "--comp-chip-label-px-sm: var(--spacing-0.5) (2px)",
        "--comp-chip-label-px-md: var(--spacing-1) (4px)",
        "--comp-chip-label-px-lg: var(--spacing-1) (4px)"
      ]
    },
    "color": {
      "layer": "[data-theme]",
      "naming": "--comp-chip-{type}-{property}[-{variant}][-{state}]",
      "tag": [
        "--comp-chip-tag-bg: var(--semantic-neutral-solid-100)",
        "--comp-chip-tag-label: var(--semantic-neutral-solid-900)",
        "--comp-chip-tag-remove: var(--semantic-neutral-solid-600)",
        "--comp-chip-tag-bg-error: var(--semantic-error-50)",
        "--comp-chip-tag-label-error: var(--semantic-error-700)",
        "--comp-chip-tag-remove-error: var(--semantic-error-500)",
        "--comp-chip-tag-bg-disabled: var(--semantic-neutral-solid-70)",
        "--comp-chip-tag-label-disabled: var(--semantic-neutral-solid-400)",
        "--comp-chip-tag-remove-disabled: var(--semantic-neutral-solid-300)"
      ],
      "filter": [
        "--comp-chip-filter-bg-off: var(--semantic-neutral-solid-70)",
        "--comp-chip-filter-label-off: var(--semantic-neutral-solid-700)",
        "--comp-chip-filter-bg-on: var(--semantic-neutral-solid-950)",
        "--comp-chip-filter-label-on: var(--semantic-neutral-solid-0)",
        "--comp-chip-filter-bg-on-brand: var(--semantic-primary-500)",
        "--comp-chip-filter-label-on-brand: var(--semantic-neutral-solid-0)",
        "--comp-chip-filter-bg-off-disabled: var(--semantic-neutral-solid-70)",
        "--comp-chip-filter-bg-on-disabled: var(--semantic-neutral-solid-100)",
        "--comp-chip-filter-label-disabled: var(--semantic-neutral-solid-400)"
      ],
      "dropdown": [
        "--comp-chip-dropdown-bg-off: var(--semantic-neutral-solid-70)",
        "--comp-chip-dropdown-label-off: var(--semantic-neutral-solid-700)",
        "--comp-chip-dropdown-bg-on: var(--semantic-neutral-solid-950)",
        "--comp-chip-dropdown-label-on: var(--semantic-neutral-solid-0)",
        "--comp-chip-dropdown-bg-on-brand: var(--semantic-primary-500)",
        "--comp-chip-dropdown-label-on-brand: var(--semantic-neutral-solid-0)",
        "--comp-chip-dropdown-bg-off-disabled: var(--semantic-neutral-solid-70)",
        "--comp-chip-dropdown-bg-on-disabled: var(--semantic-neutral-solid-100)",
        "--comp-chip-dropdown-label-disabled: var(--semantic-neutral-solid-400)",
        "--comp-chip-dropdown-badge-bg: var(--semantic-primary-500)",
        "--comp-chip-dropdown-badge-label: var(--semantic-neutral-solid-0)"
      ],
      "shared": [
        "--comp-chip-state-hover-on-bright: var(--semantic-state-on-bright-50)",
        "--comp-chip-state-pressed-on-bright: var(--semantic-state-on-bright-70)",
        "--comp-chip-state-hover-on-dim: var(--semantic-state-on-dim-50)",
        "--comp-chip-state-pressed-on-dim: var(--semantic-state-on-dim-70)",
        "--comp-chip-focus-ring: var(--semantic-primary-300)"
      ]
    }
  },

  "implementation": {
    "pattern": "CVA + cn per sub-component (each has own chipSizeVariants, color lookup maps)",
    "stateOverlay": "Absolute <span> sibling with group-hover/group-active. Root has 'group relative'. Off state uses on-bright overlay, on state uses on-dim overlay.",
    "shape": "Always rounded-full (pill). No shape variant.",
    "iconSystem": "Material Symbols Outlined via internal MatIcon helper (ChipTag close, ChipDropdown chevron). Leading icons are ReactNode props sized via iconSizeMap.",
    "files": [
      "src/components/Chip/ChipTag.tsx",
      "src/components/Chip/ChipFilter.tsx",
      "src/components/Chip/ChipDropdown.tsx",
      "src/components/Chip/index.ts"
    ],
    "dependencies": [
      "src/components/Badge/BadgeCounter.tsx"
    ],
    "exports": {
      "components": ["ChipTag", "ChipFilter", "ChipDropdown"],
      "types": ["ChipTagProps", "ChipFilterProps", "ChipDropdownProps", "ChipSize", "ChipTagIntent", "ChipFilterIntent", "ChipDropdownIntent"],
      "metadata": ["CHIP_SIZES", "CHIP_TAG_INTENTS", "CHIP_FILTER_INTENTS", "CHIP_DROPDOWN_INTENTS"]
    }
  }
}
