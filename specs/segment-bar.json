{
  "component": "SegmentBar",
  "description": "2~5개의 상호 배타적 옵션을 선택하는 세그먼트 컨트롤. 리세스(recessed) 배경 위에 선택된 버튼이 떠오르는 구조. 동일 뷰 내 필터/모드 전환에 사용. 슬라이딩 디바이더 애니메이션을 지원한다.",
  "classification": "Compound",

  "subComponents": [
    {
      "name": "SegmentBar",
      "role": "Root compound component. radiogroup role. Context provider로 value, shape, size, width, disabled, hoveredValue를 자식에게 전파.",
      "element": "div[role=radiogroup]",
      "props": {
        "shape": {
          "type": "'square' | 'circular'",
          "default": "square",
          "description": "버튼 형태. square는 표준 라운드, circular는 pill 형태."
        },
        "size": {
          "type": "'large' | 'medium' | 'small' | 'xSmall'",
          "default": "medium",
          "description": "크기 variant. 높이, 패딩, 타이포그래피, 아이콘 크기를 제어."
        },
        "width": {
          "type": "'fixed' | 'hug'",
          "default": "fixed",
          "description": "너비 모드. fixed는 균등 분할(flex-1), hug는 콘텐츠 맞춤(w-fit)."
        },
        "value": {
          "type": "string",
          "description": "현재 선택된 값 (controlled mode)."
        },
        "defaultValue": {
          "type": "string",
          "description": "초기 선택 값 (uncontrolled mode)."
        },
        "onValueChange": {
          "type": "(value: string) => void",
          "description": "선택 변경 콜백."
        },
        "disabled": {
          "type": "boolean",
          "default": false,
          "description": "전체 비활성화."
        },
        "aria-label": {
          "type": "string",
          "description": "접근성 레이블."
        },
        "children": { "type": "ReactNode" },
        "className": { "type": "string" }
      }
    },
    {
      "name": "SegmentButton",
      "role": "개별 선택 항목. radio role. Context에서 shape/size를 읽어 스타일링하고, value로 선택 상태를 결정.",
      "element": "button[role=radio]",
      "props": {
        "value": {
          "type": "string",
          "description": "옵션 식별자. SegmentBar의 value와 비교하여 선택 상태 결정."
        },
        "disabled": {
          "type": "boolean",
          "default": false,
          "description": "이 버튼만 개별 비활성화. aria-disabled 방식."
        },
        "icon": {
          "type": "ReactNode",
          "description": "레이블 좌측 아이콘. 크기는 size variant에 의해 제어."
        },
        "children": { "type": "ReactNode" },
        "className": { "type": "string" }
      }
    }
  ],

  "context": {
    "name": "SegmentBarContext",
    "sharedState": {
      "value": "현재 선택된 값",
      "onChange": "선택 변경 핸들러",
      "shape": "square | circular",
      "size": "large | medium | small | xSmall",
      "width": "fixed | hug",
      "disabled": "전체 비활성화 여부",
      "hoveredValue": "현재 호버 중인 버튼 value (디바이더 숨김용)",
      "setHoveredValue": "호버 값 setter"
    }
  },

  "variants": {
    "shape": {
      "square": {
        "description": "표준 라운드 모서리. 토큰 기반 radius.",
        "barRadius": "var(--comp-segment-bar-radius-{size})",
        "btnRadius": "var(--comp-segment-btn-radius-{size})"
      },
      "circular": {
        "description": "Pill 형태. rounded-full.",
        "barRadius": "rounded-full",
        "btnRadius": "rounded-full"
      }
    },
    "size": {
      "large": {
        "abbreviation": "lg",
        "btnHeight": "48px",
        "btnPaddingX": "var(--spacing-4) = 16px",
        "btnGap": "var(--spacing-1.5) = 6px",
        "btnRadius": "var(--radius-3) = 12px",
        "iconSize": "18px",
        "barPadding": "var(--spacing-1) = 4px",
        "barRadius": "var(--radius-4) = 16px",
        "dividerHeight": "var(--spacing-6) = 24px",
        "shadow": "0px 1px 3px rgba(0,0,0,0.04), 0px 2px 6px rgba(0,0,0,0.08)",
        "typography": "typography-17-semibold"
      },
      "medium": {
        "abbreviation": "md",
        "btnHeight": "36px",
        "btnPaddingX": "var(--spacing-3) = 12px",
        "btnGap": "var(--spacing-1.5) = 6px",
        "btnRadius": "var(--radius-2.5) = 10px",
        "iconSize": "18px",
        "barPadding": "var(--spacing-1) = 4px",
        "barRadius": "14px",
        "dividerHeight": "var(--spacing-5) = 20px",
        "shadow": "0px 1px 4px rgba(0,0,0,0.08), 0px 1px 2px rgba(0,0,0,0.04)",
        "typography": "typography-16-medium"
      },
      "small": {
        "abbreviation": "sm",
        "btnHeight": "28px",
        "btnPaddingX": "var(--spacing-2.5) = 10px",
        "btnGap": "var(--spacing-1) = 4px",
        "btnRadius": "var(--radius-2) = 8px",
        "iconSize": "var(--spacing-4) = 16px",
        "barPadding": "var(--spacing-1) = 4px",
        "barRadius": "var(--radius-3) = 12px",
        "dividerHeight": "var(--spacing-5) = 20px",
        "shadow": "0px 1px 3px rgba(0,0,0,0.06), 0px 0px 1px rgba(0,0,0,0.04)",
        "typography": "typography-14-medium"
      },
      "xSmall": {
        "abbreviation": "xs",
        "btnHeight": "20px",
        "btnPaddingX": "var(--spacing-1.5) = 6px",
        "btnGap": "var(--spacing-1) = 4px",
        "btnRadius": "var(--radius-1.5) = 6px",
        "iconSize": "var(--spacing-4) = 16px",
        "barPadding": "3px",
        "barRadius": "9px",
        "dividerHeight": "var(--spacing-4) = 16px",
        "shadow": "0px 1px 2px rgba(0,0,0,0.06), 0px 0px 1px rgba(0,0,0,0.04)",
        "typography": "typography-13-medium"
      }
    },
    "width": {
      "fixed": {
        "description": "균등 분할. SegmentButton에 flex-1. SegmentBar에 w-full.",
        "barClass": "w-full",
        "btnClass": "flex-1"
      },
      "hug": {
        "description": "콘텐츠 맞춤. SegmentButton에 w-fit. SegmentBar에 w-fit.",
        "barClass": "w-fit",
        "btnClass": "w-fit"
      }
    }
  },

  "states": {
    "default": {
      "label": "var(--comp-segment-label) → neutral-black-alpha-400",
      "border": "border border-transparent"
    },
    "active": {
      "label": "var(--comp-segment-label-active) → neutral-black-alpha-800",
      "bg": "var(--comp-segment-active-bg) → neutral-solid-0",
      "border": "var(--comp-segment-active-border) → neutral-black-alpha-600",
      "shadow": "var(--comp-segment-shadow-{size})"
    },
    "hover": {
      "overlay": "var(--comp-segment-hover) → state-on-bright-50"
    },
    "pressed": {
      "overlay": "var(--comp-segment-pressed) → state-on-bright-70"
    },
    "disabled": {
      "label": "var(--comp-segment-label-disabled) → neutral-solid-400",
      "cursor": "cursor-not-allowed"
    },
    "active-disabled": {
      "label": "var(--comp-segment-label-disabled) → neutral-solid-400",
      "bg": "var(--comp-segment-active-bg-disabled) → neutral-solid-100",
      "border": "border border-transparent",
      "shadow": "none"
    },
    "focus": {
      "all": "focus-visible:ring-2 ring-[var(--comp-segment-focus-ring)] ring-offset-1 → primary-300"
    }
  },

  "tokens": {
    "sizeTokens": {
      "scope": ":root",
      "pattern": "--comp-segment-{element}-{property}-{size}",
      "list": [
        "--comp-segment-btn-height-lg: 48px",
        "--comp-segment-btn-height-md: 36px",
        "--comp-segment-btn-height-sm: 28px",
        "--comp-segment-btn-height-xs: 20px",
        "--comp-segment-btn-px-lg: var(--spacing-4) = 16px",
        "--comp-segment-btn-px-md: var(--spacing-3) = 12px",
        "--comp-segment-btn-px-sm: var(--spacing-2.5) = 10px",
        "--comp-segment-btn-px-xs: var(--spacing-1.5) = 6px",
        "--comp-segment-btn-gap-lg: var(--spacing-1.5) = 6px",
        "--comp-segment-btn-gap-md: var(--spacing-1.5) = 6px",
        "--comp-segment-btn-gap-sm: var(--spacing-1) = 4px",
        "--comp-segment-btn-gap-xs: var(--spacing-1) = 4px",
        "--comp-segment-btn-radius-lg: var(--radius-3) = 12px",
        "--comp-segment-btn-radius-md: var(--radius-2.5) = 10px",
        "--comp-segment-btn-radius-sm: var(--radius-2) = 8px",
        "--comp-segment-btn-radius-xs: var(--radius-1.5) = 6px",
        "--comp-segment-icon-lg: 18px",
        "--comp-segment-icon-md: 18px",
        "--comp-segment-icon-sm: var(--spacing-4) = 16px",
        "--comp-segment-icon-xs: var(--spacing-4) = 16px",
        "--comp-segment-bar-padding-lg: var(--spacing-1) = 4px",
        "--comp-segment-bar-padding-md: var(--spacing-1) = 4px",
        "--comp-segment-bar-padding-sm: var(--spacing-1) = 4px",
        "--comp-segment-bar-padding-xs: 3px",
        "--comp-segment-bar-radius-lg: var(--radius-4) = 16px",
        "--comp-segment-bar-radius-md: 14px",
        "--comp-segment-bar-radius-sm: var(--radius-3) = 12px",
        "--comp-segment-bar-radius-xs: 9px",
        "--comp-segment-divider-height-lg: var(--spacing-6) = 24px",
        "--comp-segment-divider-height-md: var(--spacing-5) = 20px",
        "--comp-segment-divider-height-sm: var(--spacing-5) = 20px",
        "--comp-segment-divider-height-xs: var(--spacing-4) = 16px",
        "--comp-segment-shadow-lg: 0px 1px 3px rgba(0,0,0,0.04), 0px 2px 6px rgba(0,0,0,0.08)",
        "--comp-segment-shadow-md: 0px 1px 4px rgba(0,0,0,0.08), 0px 1px 2px rgba(0,0,0,0.04)",
        "--comp-segment-shadow-sm: 0px 1px 3px rgba(0,0,0,0.06), 0px 0px 1px rgba(0,0,0,0.04)",
        "--comp-segment-shadow-xs: 0px 1px 2px rgba(0,0,0,0.06), 0px 0px 1px rgba(0,0,0,0.04)"
      ]
    },
    "colorTokens": {
      "scope": "[data-theme]",
      "pattern": "--comp-segment-{property}[-{state}]",
      "list": [
        "--comp-segment-bar-bg: state-on-bright-50",
        "--comp-segment-label: neutral-black-alpha-400",
        "--comp-segment-label-active: neutral-black-alpha-800",
        "--comp-segment-label-disabled: neutral-solid-400",
        "--comp-segment-active-bg: neutral-solid-0",
        "--comp-segment-active-border: neutral-black-alpha-600",
        "--comp-segment-active-bg-disabled: neutral-solid-100",
        "--comp-segment-hover: state-on-bright-50",
        "--comp-segment-pressed: state-on-bright-70",
        "--comp-segment-divider: neutral-solid-200",
        "--comp-segment-focus-ring: primary-300"
      ]
    },
    "geoShapeOverrides": []
  },

  "features": {
    "animatedDividers": {
      "description": "3개 이상의 아이템이 있을 때 인접 아이템 사이에 세로 디바이더를 표시. active/hovered 버튼에 인접한 디바이더는 opacity 0으로 숨김.",
      "mechanism": "shouldShowDivider(dividerIndex, activeValue, hoveredValue, itemValues) — 좌/우 인접 값이 active 또는 hovered이면 false",
      "transition": "transition-opacity duration-fast ease-enter",
      "styling": "width 1px, height var(--comp-segment-divider-height-{size}), bg var(--comp-segment-divider)"
    },
    "activeShadow": {
      "description": "선택된 버튼에 elevation shadow를 적용하여 떠오르는 효과.",
      "mechanism": "inline style — boxShadow: var(--comp-segment-shadow-{size})",
      "disabledBehavior": "disabled 상태에서 shadow none"
    },
    "activeBorder": {
      "description": "선택된 버튼에 실선 border를 적용.",
      "token": "var(--comp-segment-active-border)",
      "disabledBehavior": "disabled 시 border-transparent"
    },
    "keyboardNavigation": {
      "role": "radiogroup",
      "pattern": "Arrow = focus + select (automatic activation)",
      "keys": {
        "ArrowRight/ArrowDown": "다음 버튼으로 이동 + 선택",
        "ArrowLeft/ArrowUp": "이전 버튼으로 이동 + 선택",
        "Home": "첫 번째 버튼으로 이동 + 선택",
        "End": "마지막 버튼으로 이동 + 선택"
      },
      "wrapAround": true,
      "disabledSkip": "aria-disabled 버튼은 포커스 대상에서 제외"
    },
    "hoverTracking": {
      "description": "hoveredValue state로 현재 호버 중인 버튼을 추적. 디바이더 숨김 로직에 사용.",
      "onMouseLeave": "SegmentBar에서 hoveredValue를 null로 리셋"
    }
  },

  "accessibility": {
    "roles": {
      "radiogroup": "SegmentBar",
      "radio": "각 SegmentButton"
    },
    "attributes": {
      "aria-checked": "선택된 버튼에 true",
      "aria-disabled": "비활성 버튼에 설정 (포커스 유지)",
      "aria-label": "SegmentBar에 설정"
    },
    "tabIndex": "선택된 버튼만 0, 나머지 -1 (roving tabindex)"
  },

  "implementation": {
    "pattern": "Compound Component + Context + CVA + cn",
    "stateOverlay": "sibling <span> + group-hover/group-active, rounded-[inherit]",
    "sizeAbbreviation": "size → abbreviation map: large→lg, medium→md, small→sm, xSmall→xs (토큰 참조 및 inline style에 사용)",
    "files": [
      "src/components/SegmentBar/SegmentBar.tsx",
      "src/components/SegmentBar/index.ts"
    ],
    "dependencies": [],
    "variantMetadata": {
      "SEGMENT_SHAPES": ["square", "circular"],
      "SEGMENT_SIZES": ["large", "medium", "small", "xSmall"],
      "SEGMENT_WIDTHS": ["fixed", "hug"]
    },
    "exportedTypes": ["SegmentBarProps", "SegmentButtonProps", "SegmentShape", "SegmentSize", "SegmentWidth"]
  }
}
