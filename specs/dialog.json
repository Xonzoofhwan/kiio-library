{
  "component": "Dialog",
  "description": "Radix UI Dialog 기반의 모달 다이얼로그 컴포넌트. 4가지 사이즈, 선택적 이미지 독/닫기 버튼/설명을 지원하며 스크롤 가능한 본문과 레이아웃 전환 가능한 하단 버튼 영역을 제공한다. Portal 렌더링 시 트리거 조상의 테마 속성을 자동 전파한다.",
  "classification": "Compound",
  "figmaNode": "7346:49770",

  "subComponents": [
    {
      "name": "Dialog",
      "role": "Root. Radix Dialog.Root를 감싸고 DialogContext와 ThemeContext를 제공. size 상태를 하위 컴포넌트에 전달.",
      "element": "RadixDialog.Root",
      "props": {
        "open": { "type": "boolean", "description": "열림 상태 (controlled)." },
        "defaultOpen": { "type": "boolean", "description": "기본 열림 상태 (uncontrolled)." },
        "onOpenChange": { "type": "(open: boolean) => void", "description": "열림/닫힘 콜백." },
        "size": {
          "type": "'xSmall' | 'small' | 'medium' | 'large'",
          "default": "small",
          "description": "다이얼로그 너비 사이즈."
        },
        "children": { "type": "ReactNode" }
      }
    },
    {
      "name": "DialogTrigger",
      "role": "트리거 요소. asChild로 자식 요소에 trigger props 전달. 내부적으로 triggerRef를 ThemeContext에 등록.",
      "element": "RadixDialog.Trigger",
      "props": {
        "asChild": { "type": "boolean", "default": true, "description": "자식 요소에 trigger props를 전달한다." },
        "children": { "type": "ReactNode" },
        "className": { "type": "string" }
      }
    },
    {
      "name": "DialogContent",
      "role": "다이얼로그 콘텐츠 패널. Portal + Overlay + 중앙 배치 패널. 테마 속성 자동 전파. 닫기 버튼, 커스텀 너비(large 사이즈) 옵션.",
      "element": "RadixDialog.Portal + RadixDialog.Overlay + RadixDialog.Content",
      "props": {
        "showCloseButton": {
          "type": "boolean",
          "default": false,
          "description": "블러 배경의 닫기 버튼 표시 여부."
        },
        "width": {
          "type": "number",
          "description": "large 사이즈의 커스텀 너비 (px). 800 초과, 화면 크기 미만. 다른 사이즈에서는 무시됨."
        },
        "children": { "type": "ReactNode" },
        "className": { "type": "string" }
      }
    },
    {
      "name": "DialogImage",
      "role": "선택적 이미지 독. full-banner(전체 너비, 비율 유지) 또는 mark(좌측 정렬, 최소 96x96) 타입.",
      "element": "div + img",
      "props": {
        "type": {
          "type": "'banner' | 'mark'",
          "default": "banner",
          "description": "이미지 레이아웃 타입."
        },
        "src": { "type": "string", "description": "이미지 소스 URL." },
        "alt": { "type": "string", "description": "접근성을 위한 대체 텍스트." },
        "className": { "type": "string" }
      }
    },
    {
      "name": "DialogTitle",
      "role": "필수 헤드라인. 스크롤 시 sticky 동작. Radix Dialog.Title로 접근성 자동 관리.",
      "element": "RadixDialog.Title",
      "props": {
        "children": { "type": "ReactNode" },
        "className": { "type": "string" }
      }
    },
    {
      "name": "DialogDescription",
      "role": "선택적 보조 텍스트. Radix Dialog.Description으로 접근성 자동 관리.",
      "element": "RadixDialog.Description",
      "props": {
        "children": { "type": "ReactNode" },
        "className": { "type": "string" }
      }
    },
    {
      "name": "DialogBody",
      "role": "선택적 스크롤 가능한 콘텐츠 영역. 자유로운 커스텀 콘텐츠 슬롯.",
      "element": "div",
      "props": {
        "children": { "type": "ReactNode" },
        "className": { "type": "string" }
      }
    },
    {
      "name": "DialogFooter",
      "role": "필수 하단 버튼 영역. 3가지 레이아웃 지원.",
      "element": "div",
      "props": {
        "layout": {
          "type": "'horizontal-hug' | 'horizontal-fill' | 'vertical-fill'",
          "default": "horizontal-hug",
          "description": "버튼 레이아웃. hug=자연 너비 우측 정렬, fill=균등 확장, vertical=세로 스택."
        },
        "children": { "type": "ReactNode" },
        "className": { "type": "string" }
      }
    },
    {
      "name": "DialogClose",
      "role": "닫기 액션 래퍼. Radix Dialog.Close로 클릭 시 다이얼로그 닫힘. Footer 내 취소 버튼에 사용.",
      "element": "RadixDialog.Close",
      "props": {
        "asChild": { "type": "boolean", "default": true },
        "children": { "type": "ReactNode" }
      }
    }
  ],

